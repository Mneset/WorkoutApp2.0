# Root .env — used by docker-compose only.
# Running locally instead? See workoutLogger/.env and
# workoutLoggerFrontend/.env (CRA and dotenv read their own dirs).

# Database
DB_ROOT_PASSWORD=your_root_password
DB_NAME=workout_logger
DB_USERNAME=workout_user
DB_PASSWORD=your_db_password

# Database behaviour — must match what the migrations create.
# DB_TIMESTAMPS must stay false: no migration adds created_at/updated_at.
DB_DIALECT=mysql
DB_UNDERSCORED=true
DB_TIMESTAMPS=false

# Auth0 — backend token validation.
# AUTH_AUDIENCE is your API identifier and must match REACT_APP_API_AUDIENCE exactly.
# AUTH_ISSUER_BASE_URL is the tenant domain, NOT the audience. Keep the trailing slash.
AUTH_AUDIENCE=http://localhost:3000/api/v1
AUTH_ISSUER_BASE_URL=https://your-tenant.us.auth0.com/

# Auth0 — frontend (compose passes these as build args; CRA inlines them at build time)
REACT_APP_ACCESS_DOMAIN=your-tenant.us.auth0.com
REACT_APP_ACCESS_CLIENT_ID=your_spa_client_id
REACT_APP_API_AUDIENCE=http://localhost:3000/api/v1

# Auth0 — M2M app used only by the Jest suite (workoutLogger/.env when running tests locally)
AUTH0_TEST_CLIENT_ID=your_m2m_client_id
AUTH0_TEST_CLIENT_SECRET=your_m2m_client_secret

# Frontend API URL (/api/v1 behind nginx, http://localhost:3000/api/v1 for local dev)
REACT_APP_API_BASE_URL=/api/v1

# Backend CORS origin (http://localhost:3001 for local dev, http://localhost for docker)
CORS_ORIGIN=http://localhost
